# ---- Server ----
# Port the Express API listens on
PORT=4000

# Where the frontend runs (used to whitelist CORS requests)
CLIENT_URL=http://localhost:3000

# ---- Database (used from Phase 2 onward) ----
# MySQL connection string for Prisma.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/supportflow"

# ---- Auth (used from Phase 3 onward) ----
# Secret used to sign JWTs. Generate a long random string for real use.
JWT_SECRET="change-me-to-a-long-random-string"
